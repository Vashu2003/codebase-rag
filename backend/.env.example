# --- LLM provider: "ollama" (local, free) or "gemini" (free API tier) ---
LLM_PROVIDER=ollama

# Ollama (local) — install from https://ollama.com, then: ollama pull qwen2.5-coder:7b
OLLAMA_HOST=http://localhost:11434
OLLAMA_MODEL=qwen2.5-coder:7b

# Gemini (free tier) — get key at https://aistudio.google.com/apikey
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.0-flash

# --- Embeddings (local, free, downloads once) ---
EMBED_MODEL=BAAI/bge-small-en-v1.5

# --- Storage ---
CHROMA_DIR=./.chroma

# --- Retrieval ---
TOP_K=8

# --- Graph-aware retrieval ---
GRAPH_ENABLED=true
GRAPH_DIR=./.graph        # sqlite code-graph sidecar
SEED_K=12                 # vector seeds before graph expansion
GRAPH_OUT_CAP=3           # max callees/definitions pulled per seed
GRAPH_IN_CAP=2            # max callers pulled per seed
GRAPH_DECAY=0.8           # neighbor score = seed_similarity * decay

# --- Reranking (cross-encoder over the merged candidate pool) ---
RERANK_ENABLED=true
RERANK_MODEL=BAAI/bge-reranker-base   # local, downloads once (~1.1GB)
RERANK_POOL=40                        # rerank at most this many candidates

# --- Token efficiency ---
CONTEXT_TOKEN_BUDGET=6000 # hard cap on assembled context (estimated)
DEDUP_OVERLAP=0.72        # token-overlap ratio treated as a duplicate
NEIGHBOR_HEAD_LINES=25    # head-trim graph-only neighbor chunks

# --- Ingest safety (this endpoint reads local files) ---
# If set, only paths inside this dir may be ingested. Leave empty for a
# single-user localhost tool; SET IT if you ever expose the server.
INGEST_ROOT=
MAX_FILES=5000
MAX_TOTAL_BYTES=200000000

# --- Ingest from a git URL (cloned server-side) ---
GIT_ALLOWED_HOSTS=github.com   # comma-separated https host allowlist
CLONE_TIMEOUT=120              # seconds before a clone is aborted
