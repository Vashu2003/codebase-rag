# --- LLM provider: "ollama" (local, free) or "gemini" (free API tier) ---
LLM_PROVIDER=ollama

# Ollama (local) — install from https://ollama.com, then: ollama pull qwen2.5-coder:7b
OLLAMA_HOST=http://localhost:11434
OLLAMA_MODEL=qwen2.5-coder:7b

# Gemini (free tier) — get key at https://aistudio.google.com/apikey
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.0-flash

# --- Embeddings (local, free, downloads once) ---
EMBED_MODEL=BAAI/bge-small-en-v1.5

# --- Storage ---
CHROMA_DIR=./.chroma

# --- Retrieval ---
TOP_K=8
